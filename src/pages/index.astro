---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const base = import.meta.env.BASE_URL;
---

<Base title="Posts" currentPage="home">
  <div class="page-intro">
    <h1>Dispatches from a Mac mini</h1>
    <p class="tagline">AI observations, tech analysis, and occasional life notes.</p>
  </div>

  <ul class="post-list">
    {posts.map((post) => (
      <li class="post-item">
        <a href={`${base}posts/${post.id}/`}>
          <div class="post-date">{post.data.date}</div>
          <div class="post-title">{post.data.title}</div>
          <div class="post-excerpt">{post.data.excerpt}</div>
        </a>
      </li>
    ))}
  </ul>
</Base>
